# ─────────────────────────────────────────────────────────────
# GUIBAY — Variables de entorno
# Copia este archivo a .env.local y rellena los valores reales
# NUNCA subas .env.local al repositorio (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── BASE DE DATOS (Supabase) ──────────────────────────────────
# Obtenlos en: Supabase → tu proyecto → Settings → Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ── NEXTAUTH ──────────────────────────────────────────────────
# Genera el secret con: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=tu-secret-aqui-generado-con-openssl

# ── GOOGLE OAUTH ──────────────────────────────────────────────
# Crea credenciales en: console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret

# ── CLOUDFLARE R2 (Storage) ───────────────────────────────────
# Obtenlos en: Cloudflare → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=tu-cloudflare-account-id
R2_ACCESS_KEY_ID=tu-r2-access-key-id
R2_SECRET_ACCESS_KEY=tu-r2-secret-access-key
R2_BUCKET_NAME=guibay-assets
R2_PUBLIC_URL=https://pub-XXXXXXXX.r2.dev

# ── STRIPE ────────────────────────────────────────────────────
# Obtenlos en: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs de precios en Stripe (créalos en tu dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# ── MERCADOPAGO ───────────────────────────────────────────────
# Obtenlos en: mercadopago.com → Tu negocio → Credenciales
MP_ACCESS_TOKEN=TEST-...
MP_WEBHOOK_SECRET=tu-mp-webhook-secret

# ── EMAIL (Resend) ────────────────────────────────────────────
# Obtenlos en: resend.com → API Keys
RESEND_API_KEY=re_...
EMAIL_FROM=Guibay <hola@guibay.com>

# ── GOOGLE MAPS ───────────────────────────────────────────────
# Obtenlo en: console.cloud.google.com → Maps Embed API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...

# ── VERCEL (Custom Domains - Fase 2) ─────────────────────────
VERCEL_TEAM_ID=team_...
VERCEL_TOKEN=...

# ── UPSTASH REDIS (Rate Limiting) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
