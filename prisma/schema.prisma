// Guibay — Schema Prisma v1.0
// ORM: Prisma 5 | DB: PostgreSQL 16

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// AUTH (NextAuth.js v5 compatible)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // null si usa OAuth
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones auth
  accounts Account[]
  sessions Session[]

  // Relaciones de negocio
  microsites    Microsite[]
  subscription  Subscription?
  addonPurchases AddonPurchase[]

  @@index([email])
}

enum UserRole {
  USER
  ADMIN
}

// ─────────────────────────────────────────────
// PLANES
// ─────────────────────────────────────────────

model Plan {
  id           String  @id @default(cuid())
  name         PlanName
  displayName  String
  priceMonthly Float
  priceAnnual  Float
  features     Json    // array de strings con features
  stripePriceIdMonthly String?
  stripePriceIdAnnual  String?

  subscriptions Subscription[]

  @@unique([name])
}

enum PlanName {
  FREE
  PRO
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  mpSubscriptionId     String?
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([stripeSubscriptionId])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

// ─────────────────────────────────────────────
// ADD-ONS
// ─────────────────────────────────────────────

model AddonPurchase {
  id        String    @id @default(cuid())
  userId    String
  addonType AddonType
  amountPaid Float
  currency  String    @default("CLP")
  expiresAt DateTime?
  lifetime  Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, addonType])
}

enum AddonType {
  CATALOG
  MAP
  GALLERY
  REVIEWS
  WHATSAPP
}

// ─────────────────────────────────────────────
// PLANTILLAS
// ─────────────────────────────────────────────

model Template {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  previewUrl  String?
  thumbnailUrl String?
  category    String       // "business" | "creative" | "professional" | "minimal"
  tier        TemplateTier @default(FREE)
  config      Json         // { colors: {}, fonts: {}, layout: {} }
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  microsites Microsite[]

  @@index([tier, isActive])
}

enum TemplateTier {
  FREE
  PRO
}

// ─────────────────────────────────────────────
// MICROSITIOS
// ─────────────────────────────────────────────

model Microsite {
  id           String          @id @default(cuid())
  slug         String          @unique
  customDomain String?         @unique
  userId       String
  templateId   String
  title        String
  published    Boolean         @default(false)
  publishedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template   @relation(fields: [templateId], references: [id])
  sections Section[]
  addons   Addon[]
  analytics Analytics[]

  @@index([userId])
  @@index([slug])
  @@index([customDomain])
}

// ─────────────────────────────────────────────
// SECCIONES
// ─────────────────────────────────────────────

model Section {
  id          String      @id @default(cuid())
  micrositeId String
  type        SectionType
  order       Int         @default(0)
  visible     Boolean     @default(true)
  data        Json        // contenido dinámico según el tipo

  microsite Microsite @relation(fields: [micrositeId], references: [id], onDelete: Cascade)

  @@index([micrositeId, order])
}

enum SectionType {
  PROFILE     // nombre, bio, foto de perfil, hero image
  SOCIAL      // links a redes sociales
  LINKS       // botones de links personalizados
  CONTACT     // email, teléfono, formulario de contacto
  TEXT        // bloque de texto libre
  VIDEO       // embed de YouTube/Vimeo
}

// ─────────────────────────────────────────────
// ADD-ONS DEL MICROSITIO
// ─────────────────────────────────────────────

model Addon {
  id          String    @id @default(cuid())
  micrositeId String
  type        AddonType
  enabled     Boolean   @default(true)
  data        Json      // configuración específica del addon

  microsite Microsite @relation(fields: [micrositeId], references: [id], onDelete: Cascade)

  @@unique([micrositeId, type])
  @@index([micrositeId])
}

// ─────────────────────────────────────────────
// ANALÍTICAS
// ─────────────────────────────────────────────

model Analytics {
  id          String        @id @default(cuid())
  micrositeId String
  eventType   AnalyticsEvent
  source      String?       // utm_source, referrer
  country     String?       // código ISO
  device      String?       // "mobile" | "desktop" | "tablet"
  userAgent   String?       @db.Text
  ip          String?       // hasheada para privacidad
  createdAt   DateTime      @default(now())

  microsite Microsite @relation(fields: [micrositeId], references: [id], onDelete: Cascade)

  @@index([micrositeId, createdAt])
  @@index([micrositeId, eventType])
}

enum AnalyticsEvent {
  PAGE_VIEW
  LINK_CLICK
  WHATSAPP_CLICK
  CATALOG_VIEW
  MAP_VIEW
  GALLERY_VIEW
  CONTACT_SUBMIT
}
